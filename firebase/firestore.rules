rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This is a private, one-day bachelor party app.
    // Participants authenticate anonymously via Expo Go.
    // Admin-only actions are enforced client-side with PIN verification.
    // A valid auth token (any anonymous sign-in) is the access gate.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
