rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Private bachelor party app — any anonymous sign-in is the access gate.
    // File size capped at 200 MB on write.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 200 * 1024 * 1024;
    }
  }
}
